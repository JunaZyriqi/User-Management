@{
    ViewData["Title"] = "Admin Dashboard";
}

<style>
    .admin-page {
        background: #f5f6f8;
        min-height: 100vh;
        padding: 35px 0;
    }

    .admin-header {
        background: #ffffff;
        border-radius: 18px;
        padding: 24px 28px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
        margin-bottom: 24px;
    }

    .admin-title {
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 4px;
    }

    .admin-subtitle {
        color: #6b7280;
        margin-bottom: 0;
    }

    .admin-card {
        background: #ffffff;
        border: none;
        border-radius: 18px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
        overflow: hidden;
    }

    .table thead th {
        background: #f9fafb;
        color: #374151;
        font-weight: 600;
        border-bottom: 1px solid #e5e7eb;
        white-space: nowrap;
    }

    .table td {
        color: #1f2937;
        vertical-align: middle;
    }

    .role-chip {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 999px;
        background: #eef2ff;
        color: #1e3a8a;
        font-weight: 600;
        font-size: 13px;
        border: 1px solid #c7d2fe;
    }

        .role-chip.admin {
            background: #fef3c7;
            color: #92400e;
            border-color: #fde68a;
        }

        .role-chip.user {
            background: #dcfce7;
            color: #166534;
            border-color: #bbf7d0;
        }

    .small-muted {
        color: #6b7280;
        font-size: 13px;
    }

    .btn-soft {
        border-radius: 10px;
        padding: 8px 16px;
        font-weight: 500;
    }

    .btn-action {
        border-radius: 8px;
        padding: 5px 12px;
        font-size: 13px;
    }

    .modal-content {
        border-radius: 18px;
        border: none;
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.12);
    }

    .modal-header {
        border-bottom: 1px solid #f0f0f0;
    }

    .modal-footer {
        border-top: 1px solid #f0f0f0;
    }

    .form-control,
    .form-select {
        border-radius: 10px;
        padding: 10px 12px;
    }

    .empty-text {
        color: #6b7280;
        text-align: center;
        padding: 25px;
    }

    .report-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        margin-bottom: 24px;
    }

    .report-card {
        background: #ffffff;
        border-radius: 18px;
        padding: 22px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
        border: 1px solid #f1f1f1;
    }

    .report-label {
        color: #6b7280;
        font-size: 14px;
        margin-bottom: 6px;
    }

    .report-value {
        color: #1f2937;
        font-size: 30px;
        font-weight: 700;
        margin-bottom: 0;
    }

    .chart-card {
        background: #ffffff;
        border-radius: 18px;
        padding: 24px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
        border: 1px solid #f1f1f1;
        margin-bottom: 24px;
    }

    .chart-title {
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 4px;
    }

    .chart-subtitle {
        color: #6b7280;
        font-size: 14px;
        margin-bottom: 24px;
    }

    .chart-body {
        display: flex;
        gap: 14px;
        align-items: stretch;
    }

    .chart-axis {
        height: 260px;
        width: 35px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        align-items: end;
        color: #9ca3af;
        font-size: 12px;
        padding: 8px 0 38px 0;
    }

    .vertical-chart {
        height: 260px;
        flex: 1;
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 18px;
        border-left: 1px solid #e5e7eb;
        border-bottom: 1px solid #e5e7eb;
        padding: 20px 18px 0 18px;
    }

    .chart-item {
        flex: 1;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .chart-bar-wrapper {
        flex: 1;
        width: 100%;
        display: flex;
        align-items: end;
        justify-content: center;
    }

    .chart-count {
        font-weight: 700;
        color: #374151;
        margin-bottom: 8px;
        font-size: 14px;
    }

    .chart-bar {
        width: 44px;
        min-height: 8px;
        border-radius: 14px 14px 0 0;
        background: linear-gradient(180deg, #c7d2fe, #818cf8);
        transition: 0.3s ease;
    }

    .chart-day {
        color: #1f2937;
        font-weight: 600;
        font-size: 13px;
        margin-top: 10px;
    }

    .chart-date {
        color: #9ca3af;
        font-size: 12px;
    }

    @@media (max-width: 768px) {
        .report-grid {
            grid-template-columns: 1fr;
        }

        .admin-header {
            flex-direction: column;
            align-items: start !important;
            gap: 16px;
        }

        .vertical-chart {
            gap: 10px;
            padding-left: 10px;
            padding-right: 10px;
        }

        .chart-bar {
            width: 30px;
        }
    }
</style>

<div class="admin-page">
    <div class="container">
        <div class="admin-header d-flex justify-content-between align-items-center">
            <div>
                <h2 class="admin-title">Admin Dashboard</h2>
                <p class="admin-subtitle">Manage users, roles, profile information and registration reports.</p>
            </div>

            <div>
                <button class="btn btn-dark btn-soft me-2" data-bs-toggle="modal" data-bs-target="#addUserModal">
                    + Add User
                </button>

                <button class="btn btn-outline-dark btn-soft" data-bs-toggle="modal" data-bs-target="#addRoleModal">
                    + Add Role
                </button>
            </div>
        </div>

        <div class="report-grid">
            <div class="report-card">
                <p class="report-label">Total Users</p>
                <p id="totalUsersValue" class="report-value">0</p>
            </div>

            <div class="report-card">
                <p class="report-label">Registered Today</p>
                <p id="todayRegistrationsValue" class="report-value">0</p>
            </div>

            <div class="report-card">
                <p class="report-label">Last 7 Days</p>
                <p id="weekRegistrationsValue" class="report-value">0</p>
            </div>
        </div>

        <div class="chart-card">
            <h5 class="chart-title">Registration Report</h5>
            <p class="chart-subtitle">Number of registered users during the last 7 days.</p>

            <div class="chart-body">
                <div class="chart-axis">
                    <span id="chartMaxLabel">0</span>
                    <span id="chartMidLabel">0</span>
                    <span>0</span>
                </div>

                <div id="registrationChart" class="vertical-chart">
                </div>
            </div>
        </div>

        <div class="admin-card">
            <div class="p-4 border-bottom">
                <h5 class="mb-0">Users & Roles</h5>
                <p class="small-muted mb-0 mt-1">View and manage user profile details.</p>
            </div>

            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Full Name</th>
                            <th>Email</th>
                            <th>Department</th>
                            <th>Position</th>
                            <th>Role</th>
                            <th>Created At</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="usersTableBody">
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Add User Modal -->
<div class="modal fade" id="addUserModal" tabindex="-1" aria-labelledby="addUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 id="addUserModalLabel" class="modal-title">Add New User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Full Name</label>
                        <input id="userFullName" class="form-control" placeholder="Enter full name" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Email</label>
                        <input id="userEmail" class="form-control" placeholder="example@imb.al" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Password</label>
                        <input id="userPassword" type="password" class="form-control" placeholder="Enter password" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Role</label>
                        <select id="userRole" class="form-select"></select>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Department</label>
                        <input id="userDepartment" class="form-control" placeholder="Example: IT" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Position</label>
                        <input id="userPosition" class="form-control" placeholder="Example: Developer" />
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary btn-soft" data-bs-dismiss="modal">
                    Cancel
                </button>
                <button type="button" class="btn btn-dark btn-soft" onclick="createUser()">
                    Save User
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Add Role Modal -->
<div class="modal fade" id="addRoleModal" tabindex="-1" aria-labelledby="addRoleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 id="addRoleModalLabel" class="modal-title">Add New Role</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Role Name</label>
                    <input id="roleName" class="form-control" placeholder="Example: Manager" />
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary btn-soft" data-bs-dismiss="modal">
                    Cancel
                </button>
                <button type="button" class="btn btn-dark btn-soft" onclick="createRole()">
                    Save Role
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Edit User Modal -->
<div class="modal fade" id="editUserModal" tabindex="-1" aria-labelledby="editUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 id="editUserModalLabel" class="modal-title">Edit User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <input id="editUserId" type="hidden" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Full Name</label>
                        <input id="editFullName" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Email</label>
                        <input id="editEmail" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Role</label>
                        <select id="editRole" class="form-select"></select>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Department</label>
                        <input id="editDepartment" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Position</label>
                        <input id="editPosition" class="form-control" />
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary btn-soft" data-bs-dismiss="modal">
                    Cancel
                </button>
                <button type="button" class="btn btn-dark btn-soft" onclick="updateUser()">
                    Save Changes
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let users = [];
        let roles = [];

        document.addEventListener("DOMContentLoaded", async function () {
            await loadRoles();
            await loadUsers();
            await loadRegistrationReport();
        });

        function escapeHtml(value) {
            if (value === null || value === undefined) {
                return '';
            }

            return value.toString()
                .replaceAll('&', '&amp;')
                .replaceAll('<', '&lt;')
                .replaceAll('>', '&gt;')
                .replaceAll('"', '&quot;')
                .replaceAll("'", '&#039;');
        }

        function formatDate(value) {
            if (!value || value.startsWith('0001-01-01')) {
                return '-';
            }

            const date = new Date(value);

            if (isNaN(date.getTime())) {
                return '-';
            }

            return date.toLocaleDateString() + ' ' + date.toLocaleTimeString([], {
                hour: '2-digit',
                minute: '2-digit'
            });
        }

        async function loadUsers() {
            const response = await fetch('/api/users');
            users = await response.json();

            document.getElementById('totalUsersValue').innerText = users.length;

            const tbody = document.getElementById('usersTableBody');
            tbody.innerHTML = '';

            if (users.length === 0) {
                tbody.innerHTML = `
                            <tr>
                                <td colspan="7" class="empty-text">No users found.</td>
                            </tr>
                        `;
                return;
            }

            users.forEach(user => {
                const roleText = user.roles && user.roles.length > 0 ? user.roles[0] : 'No role';
                const roleClass = roleText.toLowerCase().replaceAll(' ', '-');

                tbody.innerHTML += `
                            <tr>
                                <td>${escapeHtml(user.fullName)}</td>
                                <td>${escapeHtml(user.email)}</td>
                                <td>${escapeHtml(user.department || '-')}</td>
                                <td>${escapeHtml(user.position || '-')}</td>
                                <td>
                                    <span class="role-chip ${roleClass}">
                                        ${escapeHtml(roleText)}
                                    </span>
                                </td>
                                <td>${formatDate(user.createdAt)}</td>
                                <td class="text-end">
                                    <button class="btn btn-outline-dark btn-action me-1" onclick="openEditUserModal('${user.id}')">
                                        Edit
                                    </button>

                                    <button class="btn btn-outline-danger btn-action" onclick="deleteUser('${user.id}')">
                                        Delete
                                    </button>
                                </td>
                            </tr>
                        `;
            });
        }

        async function loadRoles() {
            const response = await fetch('/api/roles');
            roles = await response.json();

            fillRoleSelect('userRole');
            fillRoleSelect('editRole');
        }

        async function loadRegistrationReport() {
            const response = await fetch('/api/reports/registrations');
            const report = await response.json();

            const totalThisWeek = report.reduce((sum, item) => sum + item.count, 0);
            const todayCount = report.length > 0 ? report[report.length - 1].count : 0;

            document.getElementById('todayRegistrationsValue').innerText = todayCount;
            document.getElementById('weekRegistrationsValue').innerText = totalThisWeek;

            renderRegistrationChart(report);
        }

        function renderRegistrationChart(report) {
            const chart = document.getElementById('registrationChart');
            chart.innerHTML = '';

            const maxCount = Math.max(...report.map(item => item.count), 1);
            const midCount = Math.ceil(maxCount / 2);

            document.getElementById('chartMaxLabel').innerText = maxCount;
            document.getElementById('chartMidLabel').innerText = midCount;

            report.forEach(item => {
                const barHeight = item.count === 0 ? 8 : Math.max((item.count / maxCount) * 180, 8);

                chart.innerHTML += `
                            <div class="chart-item">
                                <div class="chart-count">${item.count}</div>

                                <div class="chart-bar-wrapper">
                                    <div class="chart-bar" style="height: ${barHeight}px;"></div>
                                </div>

                                <div class="chart-day">${escapeHtml(item.day)}</div>
                                <div class="chart-date">${escapeHtml(item.date)}</div>
                            </div>
                        `;
            });
        }

        function fillRoleSelect(selectId, selectedRole = '') {
            const select = document.getElementById(selectId);
            select.innerHTML = '';

            roles.forEach(role => {
                const selected = role.name === selectedRole ? 'selected' : '';
                select.innerHTML += `<option value="${role.name}" ${selected}>${role.name}</option>`;
            });
        }

        async function createUser() {
            const fullName = document.getElementById('userFullName').value;
            const email = document.getElementById('userEmail').value;
            const password = document.getElementById('userPassword').value;
            const role = document.getElementById('userRole').value;
            const department = document.getElementById('userDepartment').value;
            const position = document.getElementById('userPosition').value;

            const response = await fetch('/api/users', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    fullName: fullName,
                    email: email,
                    password: password,
                    role: role,
                    department: department,
                    position: position
                })
            });

            const data = await response.json();

            if (!response.ok) {
                alert(JSON.stringify(data));
                return;
            }

            document.getElementById('userFullName').value = '';
            document.getElementById('userEmail').value = '';
            document.getElementById('userPassword').value = '';
            document.getElementById('userDepartment').value = '';
            document.getElementById('userPosition').value = '';

            bootstrap.Modal.getOrCreateInstance(document.getElementById('addUserModal')).hide();

            await loadUsers();
            await loadRegistrationReport();
        }

        async function createRole() {
            const name = document.getElementById('roleName').value;

            const response = await fetch('/api/roles', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    name: name
                })
            });

            const data = await response.json();

            if (!response.ok) {
                alert(JSON.stringify(data));
                return;
            }

            document.getElementById('roleName').value = '';

            bootstrap.Modal.getOrCreateInstance(document.getElementById('addRoleModal')).hide();

            await loadRoles();
        }

        function openEditUserModal(id) {
            const user = users.find(u => u.id === id);

            if (!user) {
                alert('User not found.');
                return;
            }

            const currentRole = user.roles && user.roles.length > 0 ? user.roles[0] : '';

            document.getElementById('editUserId').value = user.id;
            document.getElementById('editFullName').value = user.fullName ?? '';
            document.getElementById('editEmail').value = user.email ?? '';
            document.getElementById('editDepartment').value = user.department ?? '';
            document.getElementById('editPosition').value = user.position ?? '';

            fillRoleSelect('editRole', currentRole);

            const modal = new bootstrap.Modal(document.getElementById('editUserModal'));
            modal.show();
        }

        async function updateUser() {
            const id = document.getElementById('editUserId').value;
            const fullName = document.getElementById('editFullName').value;
            const email = document.getElementById('editEmail').value;
            const role = document.getElementById('editRole').value;
            const department = document.getElementById('editDepartment').value;
            const position = document.getElementById('editPosition').value;

            const response = await fetch(`/api/users/${id}`, {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    fullName: fullName,
                    email: email,
                    role: role,
                    department: department,
                    position: position
                })
            });

            const data = await response.json();

            if (!response.ok) {
                alert(JSON.stringify(data));
                return;
            }

            bootstrap.Modal.getOrCreateInstance(document.getElementById('editUserModal')).hide();

            await loadUsers();
        }

        async function deleteUser(id) {
            if (!confirm('Are you sure you want to delete this user?')) {
                return;
            }

            const response = await fetch(`/api/users/${id}`, {
                method: 'DELETE'
            });

            const data = await response.json();

            if (!response.ok) {
                alert(JSON.stringify(data));
                return;
            }

            await loadUsers();
            await loadRegistrationReport();
        }
    </script>
}